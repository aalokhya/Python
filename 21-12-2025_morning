# 5. Find the maximum EVEN number in a list

num = list(map(int,input().split()))
e_n = []
max_e = None # if 0 is given when input is negative no. o/p will be wrong so use none
for i in num:
    if i % 2 == 0:
        e_n.append(i)
        if max_e is None or i > max_e :  # if is none condition not given ---- TypeError: '>' not supported between instances of 'int' and 'NoneType'
            max_e = i
print(e_n)          
