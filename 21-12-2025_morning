# 6. Count how many ODD numbers are less than 5
# this sol counts duplicates also

num = list(map(int,input().split()))
o_n = []
c = 0
for i in num:
    if i%2 != 0 and i < 5:
        o_n.append(i)
        c+=1
print("odd no. < 5 are ", o_n , "and count is ", c)

# 6. improved sol : counting the unique values and printing only them

num = list(map(int,input().split()))
o_n = set() # set stores only uniques no duplicates
for i in num:
    if i%2 != 0 and i < 5:
        o_n.add(i)  # use add() for set 
print("odd no. < 5 are ", o_n , "and count is ", len(o_n))  # for count print len()


# 7. Count frequency of each number in the list

num = list(map(int,input().split()))
freq = {}
for each in num:  # each is just a var name here 
    if each in freq:
        freq[each] += 1   # if there is already ele prst increase the count 
    else:
        freq[each] = 1   # add element into dict with count 1
print(freq)
    



