if not arr:
    print([])
else:
    i = 0  # pointer for unique elements
    for j in range(1, len(arr)):  # j = 1
        if arr[j] != arr[i]:
            i += 1
            arr[i] = arr[j] # reusing the same array to save memory

    print("Unique elements:", *arr[:i+1])

